.barrage-panel { margin-top: 8px; padding-top: 8px; border-top: 1px solid #EDF2F7; background-color: transparent; }
.barrage-head { min-height: 26px; flex-direction: row; align-items: center; justify-content: space-between; }
.barrage-title { color: #1F2937; font-size: 13px; font-weight: 800; }
