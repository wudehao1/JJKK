.barrage-state-text { display: block; margin-top: 2px; color: #9AA3B2; font-size: 9px; }
.barrage-item { position: absolute; z-index: 13; height: 23px; padding: 0 10px; border-radius: 12px; background-color: #DDF0FF; border: 1px solid rgba(111, 183, 255, 0.66); box-shadow: 0 3px 8px rgba(22, 119, 242, 0.16); flex-direction: row; align-items: center; justify-content: center; animation-name: barrageSlide; animation-timing-function: linear; animation-iteration-count: 1; animation-fill-mode: forwards; }
.barrage-text { height: 22px; line-height: 22px; font-size: 12px; font-weight: 800; white-space: nowrap; }
.barrage-color-row { height: 28px; margin-top: 5px; flex-direction: row; align-items: center; }
.barrage-color-dot { width: 19px; height: 19px; margin-right: 8px; border-radius: 10px; border: 2px solid #FFFFFF; box-shadow: 0 2px 6px rgba(15,23,42,0.12); }
.barrage-color-active { border-color: #B9D7FF; transform: scale(1.12); }
.barrage-input-row { height: 38px; margin-top: 3px; flex-direction: row; align-items: center; }
.barrage-input { flex: 1; height: 36px; padding: 0 10px; border-radius: 18px; background-color: #FFFFFF; color: #1F2937; font-size: 12px; }
.barrage-send { width: 70px; height: 36px; margin-left: 8px; border-radius: 18px; background-color: #1677F2; align-items: center; justify-content: center; }
.barrage-send-disabled { opacity: 0.58; }
.barrage-send-text { color: #FFFFFF; font-size: 12px; font-weight: 800; }
@keyframes barrageSlide {
  from { transform: translateX(0); }
  to { transform: translateX(820px); }
}
.range-tabs { margin-top: 7px; height: 34px; flex-direction: row; align-items: center; background-color: #F5F7FA; border-radius: 6px; }
.range-tab { flex: 1; height: 28px; margin: 3px; align-items: center; justify-content: center; border-radius: 5px; }
.active-range { background-color: #FFFFFF; }
.range-label { color: #747B86; font-size: 12px; }
.active-range-text { color: #1677F2; font-weight: 800; }
