<template>
  <view class="watch-page" :class="themeMode === 'dark' ? 'dark-page' : ''">
    <view class="top-card">
      <view class="top-row">
        <view class="top-main">
          <text class="eyebrow">自选基金</text>
          <text class="page-title">基金快看</text>
          <text class="refresh-time">{{ refreshTimeText }}</text>
        </view>
        <view class="top-actions">
          <view class="refresh-control" @click="refresh">
            <text class="refresh-icon" :class="loading ? 'refreshing' : ''">↻</text>
            <text class="refresh-label">{{ loading ? '刷新中' : '刷新' }}</text>
          </view>
          <button class="head-button edit-button" :loading="savingOrder" @click="toggleEdit">{{ savingOrder ? '保存中' : (editMode ? '完成' : '编辑') }}</button>
        </view>
      </view>

      <view class="summary-row">
        <view class="summary-item">
          <text class="summary-value">{{ items.length }}</text>
          <text class="summary-label">基金数</text>
        </view>
        <view class="summary-item">
          <text class="summary-value" :class="valueClassName(avgReturn)">{{ formatPercent(avgReturn) }}</text>
          <text class="summary-label">平均估算</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{ upCount }}/{{ downCount }}</text>
          <text class="summary-label">上涨/下跌</text>
        </view>
      </view>
    </view>

    <view class="search-trigger" @click="openSearchPopup">
      <text class="search-icon">⌕</text>
      <text class="search-placeholder">搜索基金代码/名称</text>
      <text class="search-action">搜索</text>
    </view>

    <view v-if="showSearchPopup" class="popup-mask" @click="closeSearchPopup">
      <view class="popup-panel" @click.stop>
        <view class="popup-head">
          <text class="popup-title">搜索基金</text>
          <button class="popup-close" @click="closeSearchPopup">返回</button>
        </view>
        <view class="search-card popup-search">
          <view class="search-box">
            <input class="search-input" v-model="keyword" placeholder="输入基金代码、名称或拼音" confirm-type="search" @confirm="search" />
            <button class="search-button" :loading="searching" @click="search">{{ searching ? '搜索中' : '搜索' }}</button>
          </view>
        </view>
        <scroll-view scroll-y class="popup-scroll">
          <view v-if="results.length > 0" class="result-card popup-result">
            <view class="result-head">
              <text class="section-title">搜索结果</text>
              <text class="section-count">{{ results.length }} 只</text>
            </view>
            <view v-for="item in results" :key="item.fundCode" class="result-row">
              <view class="result-main" @click="openFund(item.fundCode)">
                <text class="result-name">{{ item.fundName }}</text>
                <text class="result-code">{{ item.fundCode }}</text>
              </view>
              <button v-if="isWatched(item.fundCode)" class="add-button added-button" disabled>已自选</button>
              <button v-else class="add-button" @click.stop="add(item.fundCode)">加自选</button>
            </view>
          </view>
          <view v-else class="popup-empty">
            <text class="popup-empty-title">搜索官方基金</text>
            <text class="popup-empty-sub">结果会直接显示在这里，点返回回到自选列表</text>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="list-card">
      <view class="list-head">
        <text class="head-name">基金</text>
        <view v-if="!editMode" class="head-col estimate-head">
          <text class="head-col-text">估算</text>
          <view class="sort-triangles">
            <text class="sort-triangle" :class="sortMode === 'gain' ? 'active-triangle' : ''" @click.stop="changeSort('gain')">▲</text>
            <text class="sort-triangle" :class="sortMode === 'loss' ? 'active-triangle' : ''" @click.stop="changeSort('loss')">▼</text>
          </view>
        </view>
        <text v-if="!editMode" class="head-col">净值</text>
        <text v-if="editMode" class="edit-head">调整顺序或删除</text>
      </view>

      <view v-if="filteredItems.length === 0" class="empty">
        <text class="empty-title">还没有自选基金</text>
        <text class="empty-sub">搜索基金后可直接加入自选</text>
      </view>

      <view v-for="(item, index) in filteredItems" :key="item.id" class="watch-row" @click="openFund(item.fundCode)">
        <view class="fund-cell">
          <text class="fund-name">{{ item.fundName }}</text>
          <text class="fund-code">{{ item.fundCode }}</text>
          <text v-if="item.estimateTime" class="time-text">{{ estimateTimeText(item.estimateTime) }}</text>
          <text v-if="item.dataStatus" class="status-text" :class="statusClass(item.dataStatus)">{{ statusText(item.dataStatus) }}</text>
        </view>

        <view v-if="editMode" class="edit-tools">
          <view class="edit-action" :class="index === 0 ? 'sort-disabled' : ''" @click.stop="moveItem(index, -1)">
            <text class="edit-action-icon">↑</text>
            <text class="edit-action-text">上移</text>
          </view>
          <view class="edit-action" :class="index === filteredItems.length - 1 ? 'sort-disabled' : ''" @click.stop="moveItem(index, 1)">
            <text class="edit-action-icon">↓</text>
            <text class="edit-action-text">下移</text>
          </view>
          <view class="edit-action delete-action" @click.stop="remove(item.id)">
            <text class="edit-action-icon delete-icon">×</text>
            <text class="edit-action-text delete-text">删除</text>
          </view>
        </view>

        <view v-if="!editMode" class="metric-cell">
          <text class="main-return" :class="valueClassName(item.estimateReturnPct)">{{ formatPercent(item.estimateReturnPct) }}</text>
          <text class="metric-sub">估 {{ formatNav(item.estimateNav) }}</text>
        </view>

        <view v-if="!editMode" class="metric-cell right-cell">
          <text class="nav-value">{{ formatNav(item.latestUnitNav) }}</text>
          <text class="metric-sub">{{ dateText(item.latestNavDate) }}</text>
        </view>

      </view>
    </view>

    <view class="disclaimer-card">
      <text class="disclaimer-title">免责声明</text>
      <text class="disclaimer-text">基金估值、分时走势和涨跌幅由公开数据及模型估算生成，可能与基金公司最终披露净值存在差异，仅供信息参考，不构成任何投资建议或收益承诺。</text>
    </view>
  </view>
</template>

<script lang="uts">
import { applyTheme, getThemeMode, setThemeMode } from '../../common/theme.js'
import { ensureUser, searchFunds, searchOfficialFunds, listWatchlist, addWatchlist, reorderWatchlist, deleteWatchlist, percent, navText, valueClass } from '../../common/api.js'

export default {
  data() {
    return {
      themeMode: getThemeMode(),
      userId: 0,
      items: [],
      results: [],
      keyword: '',
      loading: false,
      searching: false,
      editMode: false,
      savingOrder: false,
      orderDirty: false,
      showSearchPopup: false,
      lastRefreshAt: '',
      sortMode: ''
    }
  },
  computed: {
    upCount() {
      return this.items.filter((item) => Number(item.estimateReturnPct || 0) > 0).length
    },
    downCount() {
      return this.items.filter((item) => Number(item.estimateReturnPct || 0) < 0).length
    },
    avgReturn() {
      const values = this.items
        .map((item) => Number(item.estimateReturnPct))
        .filter((value) => Number.isFinite(value))
      if (!values.length) return null
      const total = values.reduce((sum, value) => sum + value, 0)
      return total / values.length
    },
    filteredItems() {
      if (this.editMode || !this.sortMode) return this.items
      const sorted = this.items.slice()
      sorted.sort((left, right) => {
        const leftValue = this.estimateSortValue(left)
        const rightValue = this.estimateSortValue(right)
        if (leftValue === null && rightValue === null) return Number(left.displayOrder || 0) - Number(right.displayOrder || 0)
        if (leftValue === null) return 1
        if (rightValue === null) return -1
        return this.sortMode === 'gain' ? rightValue - leftValue : leftValue - rightValue
      })
      return sorted
    },
    refreshTimeText() {
      return this.lastRefreshAt ? '本页刷新 ' + this.lastRefreshAt : '等待刷新'
    }
  },
  onShow() {
    this.applyPageTheme()
    ensureUser().then((userId) => {
      this.userId = userId
      this.load(false)
    })
  },
  methods: {
    applyPageTheme() {
      this.themeMode = getThemeMode()
      applyTheme()
    },
    load(showTip) {
      if (!this.userId) return
      this.loading = true
      listWatchlist(this.userId).then((items) => {
        this.items = this.normalizeItems(items || [])
        this.lastRefreshAt = this.nowText()
        if (showTip) uni.showToast({ title: '已刷新', icon: 'none' })
      }).finally(() => {
        this.loading = false
      })
    },
    refresh() {
      this.load(true)
    },
    toggleEdit() {
      if (this.savingOrder) return
      if (!this.editMode) {
        this.sortMode = ''
        this.orderDirty = false
        this.editMode = true
        return
      }
      if (!this.orderDirty) {
        this.editMode = false
        return
      }
      this.saveOrder()
    },
    changeSort(mode) {
      if (this.editMode) return
      this.sortMode = this.sortMode === mode ? '' : mode
    },
    estimateSortValue(item) {
      const value = item ? Number(item.estimateReturnPct) : NaN
      return Number.isFinite(value) ? value : null
    },
    openFund(fundCode) {
      uni.navigateTo({ url: '/pages/fund-detail/fund-detail?fundCode=' + fundCode })
    },
    openSearchPopup() {
      this.showSearchPopup = true
    },
    closeSearchPopup() {
      this.showSearchPopup = false
      this.results = []
      this.keyword = ''
    },
    search() {
      const keyword = (this.keyword || '').trim()
      if (!keyword) {
        this.results = []
        uni.showToast({ title: '请输入基金代码或名称', icon: 'none' })
        return
      }
      this.searching = true
      searchFunds(keyword, 1, 30).then((page) => {
        const localItems = page.items || []
        if (localItems.length > 0) {
          this.results = localItems
          return null
        }
        return searchOfficialFunds(keyword, 30).then((official) => {
          this.results = official.items || []
          if (this.results.length === 0) {
            uni.showToast({ title: '未找到基金', icon: 'none' })
          }
          return official
        })
      }).finally(() => {
        this.searching = false
      })
    },
    isWatched(fundCode) {
      return this.items.some((item) => String(item.fundCode) === String(fundCode))
    },
    add(fundCode) {
      addWatchlist(this.userId, {
        fundCode,
        groupName: '默认',
        displayOrder: this.items.length,
        remark: '',
        alertEnabled: false
      }).then((item) => {
        const next = this.items.filter((current) => String(current.fundCode) !== String(item.fundCode))
        this.items = this.normalizeItems(next.concat([item]))
        uni.showToast({ title: '已加入自选', icon: 'success' })
      })
    },
    normalizeItems(items) {
      return items.slice().sort((left, right) => {
        const leftOrder = Number(left.displayOrder || 0)
        const rightOrder = Number(right.displayOrder || 0)
        if (leftOrder !== rightOrder) return leftOrder - rightOrder
        return Number(right.id || 0) - Number(left.id || 0)
      })
    },
    moveItem(index, direction) {
      if (!this.editMode) return
      const targetIndex = index + direction
      if (targetIndex < 0 || targetIndex >= this.items.length) return
      const next = this.items.slice()
      const current = next[index]
      next[index] = next[targetIndex]
      next[targetIndex] = current
      this.items = next.map((item, itemIndex) => ({ ...item, displayOrder: itemIndex }))
      this.orderDirty = true
    },
    saveOrder() {
      this.savingOrder = true
      const payload = this.items.map((item, index) => ({ watchId: item.id, displayOrder: index }))
      reorderWatchlist(this.userId, payload).then((items) => {
        this.items = this.normalizeItems(items || this.items)
        this.orderDirty = false
        this.editMode = false
        uni.showToast({ title: '排序已保存', icon: 'none' })
      }).finally(() => {
        this.savingOrder = false
      })
    },
    remove(id) {
      uni.showModal({
        title: '删除自选？',
        content: '确认删除这只基金吗',
        success: (res) => {
          if (res.confirm) deleteWatchlist(this.userId, id).then(() => this.load(false))
        }
      })
    },
    nowText() {
      const now = new Date()
      const pad = (value) => String(value).padStart(2, '0')
      return pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds())
    },
    estimateTimeText(value) {
      if (!value) return ''
      const text = String(value).replace('T', ' ')
      return text.slice(5, 16)
    },
    dateText(value) {
      if (!value) return '--'
      return String(value).slice(5, 10)
    },
    statusText(status) {
      const key = String(status || '').toUpperCase()
      if (key === 'CLOSED') return '已收盘'
      if (key === 'DELAYED') return '估算延迟'
      if (key === 'ERROR') return '估算异常'
      return '实时估算'
    },
    statusClass(status) {
      const key = String(status || '').toUpperCase()
      if (key === 'CLOSED') return 'status-closed'
      if (key === 'DELAYED') return 'status-delayed'
      if (key === 'ERROR') return 'status-error'
      return 'status-normal'
    },
    formatPercent(value) { return percent(value) },
    formatNav(value) { return navText(value) },
    valueClassName(value) { return valueClass(value) }
  }
}
</script>

<style>
