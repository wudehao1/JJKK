rn String(source).replace('T', ' ').slice(5, 16);\n        }\n    },\n    onLoad(options) {\n        this.fundCode = options.fundCode || '';\n        this.loadDetail();\n        this.load();\n        this.loadBarrages();\n    },\n    onReady() {\n        this.measureChart();\n    },\n    onShow() {\n        this.applyPageTheme();\n        this.measureChart();\n        this.startTimer();\n        ensureUser().then((userId = null) => {\n            this.userId = userId;\n            this.loadWatchState();\n            this.loadTradeMarkers();\n        }).catch(() => { });\n    },\n    onHide() {\n        this.stopTimer();\n    },\n    onUnload() {\n        this.stopTimer();\n    },\n    methods: {\n        applyPageTheme() {\n            this.themeMode = getThemeMode();\n            applyTheme();\n        },\n        goBack() {\n            uni.navigateBack(new UTSJSONObject({ delta: 1 }));\n        },\n        loadWatchState() {\n            if (!this.userId || !this.fundCode)\n                return null;\n            listWatchlist(this.userId).then((items = null) => {\n                const current = (items || []).find((item = null) => { return String(item.fundCode) === String(this.fundCode); });\n                this.watchId = current ? Number(current.id || 0) : 0;\n            }).catch(() => { });\n        },\n        loadTradeMarkers() {\n            if (!this.userId || !this.fundCode)\n                return null;\n            getHoldingTransactions(this.userId, new UTSJSONObject({ fundCode: this.fundCode, limit: 200 })).then((items = null) => {\n                this.tradeTransactions = (items || []).filter((item = null) => {\n                    const sourceType = String(item.sourceType || '').toUpperCase();\n                    const txnType = String(item.txnType || '').toUpperCase();\n                    return Number(item.id || 0) > 0\n                        && Number(item.nav || 0) > 0\n                        && String(item.fundCode || '') === String(thi